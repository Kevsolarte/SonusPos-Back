// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Negocio {
  id        String   @id @default(uuid())
  nombre    String
  ruc       String?  @unique
  direccion String?
  telefono  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  productos   Producto[]
  clientes    Cliente[]
  ventas      Venta[]
  movimientos MovimientoInventario[]
}

enum Role {
  SUPERADMIN
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  negocioId    String?
  negocio      Negocio? @relation(fields: [negocioId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum TipoVenta {
  PESO
  UNIDAD
}

enum UnidadMedida {
  KG
  G
  L
  ML
  UNIDAD
  PZA
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  MERMA
  AJUSTE
}

model Producto {
  id          String  @id @default(uuid())
  negocioId   String?
  nombre      String
  codigoBarra String?
  descripcion String?
  imagenUrl   String?

  tipoVenta    TipoVenta
  unidadMedida UnidadMedida

  ventadDetalles VentaDetalle[]

  inventario  Inventario?
  precio      Precio?
  movimientos MovimientoInventario[]

  negocio   Negocio? @relation(fields: [negocioId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  activo    Boolean  @default(true)

  @@unique([nombre, negocioId])
  @@unique([codigoBarra, negocioId])
}

// -----------------------

model Inventario {
  id         String @id @default(uuid())
  productoId String @unique

  stockActual Decimal  @db.Decimal(10, 3)
  stockMin    Decimal? @db.Decimal(10, 3)
  stockMax    Decimal? @db.Decimal(10, 3)

  alertastockbaja Boolean?

  ubicacion String?

  producto Producto @relation(fields: [productoId], references: [id])

  updatedAt DateTime @updatedAt
}

// -----------------------

model Precio {
  id         String @id @default(uuid())
  productoId String @unique

  preciocompra Decimal @db.Decimal(10, 3)

  precioDetal Decimal  @db.Decimal(10, 2)
  precioMayor Decimal? @db.Decimal(10, 2)

  producto Producto @relation(fields: [productoId], references: [id])

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// -----------------------

model MovimientoInventario {
  id         String @id @default(uuid())
  negocioId  String?
  productoId String

  tipo     TipoMovimiento
  cantidad Decimal        @db.Decimal(10, 2)
  motivo   String?

  createdAt DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
  negocio  Negocio?  @relation(fields: [negocioId], references: [id])
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  PAGO_MOVIL
  EFECTIVO_USD
  EFECTIVO_VES
}

enum EstadoVenta {
  ABIERTA
  PAGADA
  ANULADA
}

model Cliente {
  id        String  @id @default(uuid())
  negocioId String?
  nombre    String
  documento String?
  telefono  String?
  email     String?
  direccion String?

  ventas Venta[]

  negocio   Negocio?  @relation(fields: [negocioId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documento, negocioId])
  @@index([nombre])
  @@index([documento])
}

model Venta {
  id        String @id @default(uuid())
  negocioId String?

  // Folio / número (lo generas en backend)
  numero String

  // Cliente opcional
  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  estado EstadoVenta @default(PAGADA)

  // Totales (calculados por backend)
  subtotal  Decimal @db.Decimal(10, 2)
  descuento Decimal @default(0) @db.Decimal(10, 2)
  impuesto  Decimal @default(0) @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  nota String?

  detalles VentaDetalle[]
  pagos    VentaPago[]

  negocio   Negocio?  @relation(fields: [negocioId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([numero, negocioId])
  @@index([createdAt])
  @@index([clienteId])
}

model VentaDetalle {
  id String @id @default(uuid())

  ventaId String
  venta   Venta  @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  productoId String
  producto   Producto @relation(fields: [productoId], references: [id])

  // Cantidad vendida (PESO admite decimal; UNIDAD se valida en Zod/backend)
  cantidad Decimal @db.Decimal(10, 3)

  // Precios/totales (calculados por backend al momento de la venta)
  precioUnitario Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  // Snapshot del producto para auditoría
  tipoVenta    TipoVenta
  unidadMedida UnidadMedida

  createdAt DateTime @default(now())

  @@index([ventaId])
  @@index([productoId])
}

model VentaPago {
  id String @id @default(uuid())

  ventaId String
  venta   Venta  @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  metodo MetodoPago
  monto  Decimal    @db.Decimal(10, 2)

  // Opcionales por método
  referencia String?
  ultimos4   String?
  recibido   Decimal? @db.Decimal(10, 2)
  cambio     Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([ventaId])
  @@index([metodo])
}
